# ──────────────────────────────────────────────
# SKILLBRIDGE — Environment Variables
# Copy this to .env.local for local dev
# Add ALL these to Vercel → Settings → Environment Variables
# ──────────────────────────────────────────────

# Google OAuth2 Credentials
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Your Gmail (the sender)
SENDER_EMAIL=sanjayias91@gmail.com
SENDER_NAME=Sanjay R — SkillBridge

# Google Sheets — where form data is stored
# Get Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Calendar — your event ID
# This is your real CS02 Daily Coding Practice event
GOOGLE_CALENDAR_EVENT_ID=292d0s1tbbnjmjkq95jueomvgk
GOOGLE_CALENDAR_ID=sanjayias91@gmail.com
